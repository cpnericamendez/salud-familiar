rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /familyData/{document} {
      allow read, write: if true;
    }
    match /memberPhotos/{document} {
      allow read, write: if true;
    }
    match /pushTokens/{document} {
      allow read, write: if true;
    }
    match /fcmTokens/{document} {
      allow read, write: if true;
    }
  }
}
